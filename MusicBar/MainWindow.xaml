<Window x:Class="MusicBar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MusicBar"
        Width="484" Height="48"
        MinWidth="400" MaxWidth="604"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Loaded="OnLoaded"
        SourceInitialized="OnSourceInitialized"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        MouseMove="OnMouseMove"
        MouseLeftButtonUp="OnMouseLeftButtonUp">
    <Window.Resources>
        <Style x:Key="ControlButton" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="1,0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface" Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="{DynamicResource ControlPressedBrush}" />
                                <Setter Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.94" ScaleY="0.94" /></Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.28" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LauncherButton" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="1,0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="{DynamicResource ControlPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="0" Background="{DynamicResource PanelBrush}"
            BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,1,0,0">

        <Grid Margin="4,3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid x:Name="MediaInfoPanel" Grid.ColumnSpan="2" Background="Transparent"
                  Cursor="Hand" ToolTip="双击显示或收起播放器"
                  PreviewMouseLeftButtonDown="OnMediaInfoMouseLeftButtonDown">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasMediaSession}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="40" Height="40" CornerRadius="7" Background="{DynamicResource ArtworkSurfaceBrush}" ClipToBounds="True">
                    <Grid>
                        <Image Source="{Binding Artwork}" Stretch="UniformToFill" />
                        <TextBlock Text="&#xE8D6;" FontFamily="Segoe Fluent Icons" FontSize="18"
                                   Foreground="{DynamicResource ArtworkIconBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Panel.ZIndex="-1" />
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="8,0,5,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="18" />
                        <RowDefinition Height="22" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="11.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                        <Run Text="{Binding Title}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                        <Run Text="  ·  " Foreground="{DynamicResource TextSecondary}" />
                        <Run Text="{Binding ArtistAndSource}" Foreground="{DynamicResource TextSecondary}" />
                    </TextBlock>
                    <TextBlock Grid.Row="1" Text="{Binding CurrentLyric}" Foreground="{DynamicResource AccentBrush}"
                               FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                </Grid>
            </Grid>

            <Grid Grid.ColumnSpan="2" Margin="2,0,5,0">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasMediaSession}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding LauncherHint}" Width="112" Margin="4,0,4,0"
                           Foreground="{DynamicResource TextSecondary}" FontSize="11.5"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                <ItemsControl Grid.Column="1" ItemsSource="{Binding InstalledPlayers}" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource LauncherButton}" ToolTip="{Binding Name}"
                                    Command="{Binding DataContext.LaunchPlayerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">
                                <Grid Width="28" Height="28">
                                    <Border CornerRadius="6" Background="{DynamicResource ArtworkSurfaceBrush}" />
                                    <TextBlock Text="&#xE8D6;" FontFamily="Segoe Fluent Icons" FontSize="15"
                                               Foreground="{DynamicResource ArtworkIconBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <Image Source="{Binding Icon}" Stretch="Uniform" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ControlButton}" Content="&#xE892;" Command="{Binding PreviousCommand}"
                        IsEnabled="{Binding CanPrevious}" ToolTip="上一首" />
                <Button Width="40" Height="40" Margin="2,0" BorderThickness="0" Cursor="Hand"
                        Command="{Binding TogglePlayPauseCommand}" ToolTip="播放 / 暂停">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="PlaySurface" Background="{DynamicResource PlaySurfaceBrush}" CornerRadius="20">
                                <TextBlock Text="{Binding PlayPauseGlyph}" FontFamily="Segoe Fluent Icons" FontSize="21"
                                           Foreground="{DynamicResource PlayForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="PlaySurface" Property="Opacity" Value="0.86" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="PlaySurface" Property="Opacity" Value="0.78" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="PlaySurface" Property="Opacity" Value="0.35" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Style="{StaticResource ControlButton}" Content="&#xE893;" Command="{Binding NextCommand}"
                        IsEnabled="{Binding CanNext}" ToolTip="下一首" />
            </StackPanel>
        </Grid>
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="重新搜索在线歌词" Click="OnRefreshOnlineLyricsClick" />
                <MenuItem Header="加载本地 LRC 歌词…" Click="OnLoadLyricsClick" />
                <Separator />
                <MenuItem Header="校准歌词同步">
                    <MenuItem Header="设置当前播放时间…" Click="OnCalibratePositionClick" />
                    <Separator />
                    <MenuItem Header="歌词快进 1 秒" Tag="1" Click="OnAdjustLyricsOffsetClick" />
                    <MenuItem Header="歌词后退 1 秒" Tag="-1" Click="OnAdjustLyricsOffsetClick" />
                    <MenuItem Header="重置歌词偏移" Click="OnResetLyricsOffsetClick" />
                </MenuItem>
                <MenuItem Header="重新贴靠任务栏" Click="OnDockClick" />
                <Separator />
                <MenuItem Header="退出 MusicBar" Click="OnExitClick" />
            </ContextMenu>
        </Border.ContextMenu>
    </Border>
</Window>
