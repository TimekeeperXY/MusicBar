<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows10.0.26100.0</TargetFramework>
    <SupportedOSPlatformVersion>10.0.17763.0</SupportedOSPlatformVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AssemblyName>MusicBar</AssemblyName>
    <RootNamespace>MusicBar</RootNamespace>
    <Version>0.2.0-alpha.14</Version>
    <ApplicationIcon>Assets\MusicBar.ico</ApplicationIcon>
    <Product>MusicBar</Product>
    <Description>Windows taskbar media controller</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
  </ItemGroup>

</Project>
