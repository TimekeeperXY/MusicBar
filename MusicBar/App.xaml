<Application x:Class="MusicBar.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MusicBar"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#34000000" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#20FFFFFF" />
        <SolidColorBrush x:Key="TextPrimary" Color="#F7F8FA" />
        <SolidColorBrush x:Key="TextSecondary" Color="#AAB0BA" />
        <SolidColorBrush x:Key="AccentBrush" Color="#78D4FF" />
        <SolidColorBrush x:Key="ControlHoverBrush" Color="#22FFFFFF" />
        <SolidColorBrush x:Key="ControlPressedBrush" Color="#3AFFFFFF" />
        <SolidColorBrush x:Key="PlaySurfaceBrush" Color="#EFF2F4" />
        <SolidColorBrush x:Key="PlayForegroundBrush" Color="#181A1F" />
        <SolidColorBrush x:Key="ArtworkSurfaceBrush" Color="#292D35" />
        <SolidColorBrush x:Key="ArtworkIconBrush" Color="#737B87" />
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="{DynamicResource PlayForegroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PlaySurfaceBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,5" />
        </Style>
    </Application.Resources>
</Application>
